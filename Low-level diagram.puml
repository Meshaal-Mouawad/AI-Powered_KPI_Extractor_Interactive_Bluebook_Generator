@startuml
title Programmatic Formula Extraction (Low-Level) Decision-Making Process.

start

:Input code_context;
:Strip comments and normalize whitespace;

if (DAX DEFINE/RETURN statement?) then (yes)
  :Extract RETURN body;
else (no)
  if (SQL SELECT ... AS ...?) then (yes)
    :Take last expression/alias;
    :Unwrap CAST, NULLIF, COALESCE;
  else (no)
    if (C-like 'return expr'?) then (yes)
      :Use expression from return;
      :Set name = "Result";
    else (no)
      if (Assignment '=' or ':='?) then (yes)
        :LHS becomes variable name;
        :RHS becomes expression;
      else (no)
        if (VB 'Return expr'?) then (yes)
          :Use expression from Return;
        else (no)
          if (ABAP 'lhs = expr.'?) then (yes)
            :Use expression before period;
          else (no)
            if (Percent form 100*(a/b)?) then (yes)
              :Extract the division (a/b);
            else (no)
              :Perform generic sweep;
              :Prefer percent, then last division;
            endif
          endif
        endif
      endif
    endif
  endif
endif

:Format as LaTeX with friendly tokens;

stop

@enduml