@startuml Bluebook_Components
title AI-Powered KPI Extractor & Interactive Bluebook Generator - Components

skinparam componentStyle rectangle
skinparam shadowing false
skinparam monochrome false

package "User's Repo" {
  [Source .py Files] as SRC
}

package "bluebook_generator" {
  [kpi_extractor.py] as EX
  [ai_generator.py] as AI
  [main.py] as CORE
  [cli.py] as CLI
  [templates/kpi_template.rst.j2] as TPL
}

package "Sphinx" {
  [docs/ .rst pages] as RST
  [HTML Builder] as SBUILDER
  [HTML Output (_build)] as HTML
}

SRC -down-> EX : scan
EX -right-> CORE : list of KPIs {name, file, line, context}
CORE -down-> AI : text details (JSON)
AI -up-> CORE : description, objective, unit, ...
CORE -right-> TPL : render per-KPI
CORE -down-> RST : write .rst
RST -right-> SBUILDER : build html
SBUILDER -down-> HTML : final site
CLI -left-> CORE : bluebook generate <src>

@enduml

@startuml Bluebook_Flow
title KPI Generation Flow (Activity)

start
:User runs\n`bluebook generate <src>` via CLI;
:Find KPIs in <src>\nscan .py for '# KPI: <Name>'\nattach file + line + context;
if (Any KPI found?) then (yes)
  repeat
    :Pick next KPI;
    :Scope function with AST to\nget exact "Code Context";
    :Generate formula (MathJax)\nfrom code expression;
    :Ask AI for narrative fields\n(description, objective, ...);
    :Infer unit_of_measure if vague;
    :Render KPI page from Jinja\n-> .rst file;
  repeat while (KPIs left?)
  :Update docs/index.rst;
  :Run sphinx-build -> HTML;
  stop
else (no)
  :Exit with 'No KPIs found';
  stop
endif
@enduml