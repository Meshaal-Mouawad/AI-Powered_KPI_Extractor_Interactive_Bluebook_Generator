@startuml Manual_vs_Automated_KPI

title Traditional Manual Documentation vs Automated KPI Extraction

start

split
  partition "Traditional Manual Documentation" {
    :Traditional Manual Documentation;
    :Manual Data Entry;
    :Spreadsheet Updates;
    :Error-Prone Operations;
    :Delayed Reporting;
  }
split again
