@startuml
actor "Developer" as Dev
actor "Bluebook Manager" as BM
actor "Business Analyst / RACI Stakeholders" as BA

rectangle "As-Is KPI Update Workflow" {
  usecase "Consult manual Bluebook (PDF)" as UC1
  usecase "Search codebase for KPI" as UC2
  usecase "Update KPI in IDE" as UC3
  usecase "Report update to Bluebook team" as UC4
  usecase "Update master Bluebook doc" as UC5
  usecase "Distribute updated Bluebook (RACI)" as UC6
}

Dev --> UC1
Dev --> UC2
Dev --> UC3
Dev --> UC4
BM --> UC5
BM --> UC6
BA --> UC6
@enduml