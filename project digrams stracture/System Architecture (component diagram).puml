@startuml AI-Powered_KPI_Extractor_Interactive_Bluebook_Generator_Components
title AI-Powered KPI Extractor & Interactive Bluebook - Component Architecture

skinparam componentStyle rectangle
skinparam wrapWidth 200
skinparam maxMessageSize 120

package "User Interfaces" {
  [CLI Runner] as cli
  [Web App / Bluebook UI] as web
}

package "Core Services" {
  [Directory Scanner] as scanner
  [Language Hinting] as langhint
  [KPI Extractor] as extractor
  [Comment Parser (Formula)] as parser
  [AI Narrative Generator] as ai
  [Bluebook Renderer (Templates)] as renderer
  [IDE Deep-Link Adapter] as ide
  [KB Orchestrator] as kbo
}

package "Knowledge & Storage" {
  [Knowledge Base (KB Store)] as kb
  [Bluebook Artifacts (HTML/Docs)] as book
  [Config/Env] as cfg
  [File System / Repos] as fs
}

package "External Tools" {
  [PyCharm] as pycharm
  [VS Code] as vscode
}

' Interactions
cli --> cfg : reads settings
web --> cfg : reads settings
cli --> scanner : start scan
web --> scanner : admin-triggered scan (optional)
scanner --> fs : traverse directories/files
scanner --> langhint : infer language by extension

scanner --> extractor : submit file content + language hint
extractor --> parser : optional "Formula:" extraction
extractor --> kbo : produce KPI candidates
kbo --> kb : load prior curation\nmerge/override curated fields
kbo --> ai : enhance descriptions, units, rationale (optional)
kbo --> renderer : submit enriched KPI records

renderer --> book : write interactive Bluebook pages
renderer --> ide : embed deep links (file + line → IDE)
web --> book : serve pages
web --> kb : read/write edits via KB editor (persisted)
web --> ide : redirect clicks to IDE links

ide --> pycharm : pycharm://open?file=...&line=...
ide --> vscode : vscode://file/...:line

@enduml